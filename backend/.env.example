PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
LOG_PRETTY=true
LOG_SINGLE_LINE=true

# Postgres / Supabase connection string
DATABASE_URL=

# HS256 signing secret for starter auth flow
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=lockedin-api
JWT_AUDIENCE=lockedin-mobile
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
SCHEDULER_SECRET=replace-with-long-random-secret
MISS_EXTENSION_DAYS=7
LOCK_VAULT_RELAY_ENABLED=false
LOCK_VAULT_RELAY_INTERVAL_MS=15000
LOCK_VAULT_RELAY_BATCH_SIZE=5
RUNTIME_SCHEDULER_ENABLED=false
RUNTIME_SCHEDULER_INTERVAL_MS=15000
RUNTIME_SCHEDULER_BATCH_SIZE=5
ANSWER_VALIDATOR_HYBRID_ENABLED=false
OPENAI_API_KEY=
OPENAI_RESPONSES_BASE_URL=https://api.openai.com/v1
OPENAI_VALIDATOR_MODEL=gpt-4o-mini
OPENAI_VALIDATOR_TIMEOUT_MS=4000
YIELD_STRATEGY_ENABLED=false
YIELD_STRATEGY_KIND=fixed_apy_v1
YIELD_FIXED_APY_BPS=800
YIELD_HARVEST_INTERVAL_SECONDS=86400

# LockVault relay config
SOLANA_RPC_URL=https://api.devnet.solana.com
LOCK_VAULT_PROGRAM_ID=
YIELD_SPLITTER_PROGRAM_ID=
COMMUNITY_POT_PROGRAM_ID=
LOCK_VAULT_USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
LOCK_VAULT_SKR_MINT=
LOCK_VAULT_WORKER_PRIVATE_KEY=
YIELD_SPLITTER_WORKER_PRIVATE_KEY=
COMMUNITY_POT_WORKER_PRIVATE_KEY=

# Comma-separated browser origins allowed to call this API
# Keep localhost + your LAN frontend URL here during development
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
